# ─────────────────────────────────────────────────────────────
#  Callendulla — environment template
#  cp .env.example .env  →  заполни значения с пометкой [REQUIRED]
#  Никогда не коммить .env в git! Он в .gitignore.
# ─────────────────────────────────────────────────────────────

# ─── Telegram ────────────────────────────────────────────────
# [REQUIRED] Токен от @BotFather. Формат: 1234567:AAH...
TELEGRAM_BOT_TOKEN=

# [REQUIRED] Твой Telegram user_id. Узнать: написать @userinfobot
# Этот юзер автоматически получит роль 'owner' при первом /start.
OWNER_TG_ID=

# Режим бота: polling или webhook. ВЗАИМОИСКЛЮЧАЮЩИ — Telegram API кинет
# ошибку, если включишь оба. polling проще для домашнего стенда, webhook
# обязателен для прод-нагрузки и нескольких реплик.
BOT_MODE=polling

# Если BOT_MODE=webhook:
# WEBHOOK_HOST=https://callendulla.example.com
# WEBHOOK_PATH=/tg/SECRET_PATH_HERE       # сгенерируй: openssl rand -hex 16
#                                         # ВАЖНО: URL-путь попадает в access-log
#                                         # nginx/Caddy. Это не секрет, лишь
#                                         # обфускация. Реальная защита — header
#                                         # X-Telegram-Bot-Api-Secret-Token ниже.
# WEBHOOK_SECRET=SECRET_HERE              # ≥32 байт: openssl rand -hex 32
#                                         # Telegram шлёт его в header
#                                         # X-Telegram-Bot-Api-Secret-Token,
#                                         # сервер сверяет до обработки апдейта.
#                                         # Header в логи не попадает.

# ─── LLM провайдер ──────────────────────────────────────────
# Один из: gemini, openai, anthropic, ollama
# Только этот провайдер будет использоваться. Не миксуй.
#
# Стоимость, актуально на 05.2026:
#  - gemini    — если в Google Cloud Console активирован Billing для
#                твоего проекта, ВСЕ запросы платные, даже на моделях
#                с формальным free tier. Без Billing — free tier с
#                жёсткими лимитами RPM/RPD, легко превышается.
#  - openai    — pay-per-token, дешевле gpt-4o-mini ≈ $0.15/1M in.
#  - anthropic — pay-per-token, haiku-4-5 ≈ $1/$5 за 1M in/out.
#  - ollama    — бесплатно, но нужен локальный GPU или мощный CPU.
#
# Для лёгкой няньки на 5-10 событий в день хватит любого. Считай
# заранее: одна задача = ~2 LLM вызова (генерация текста пинка +
# decide_next при игноре). 100 пинков/день * 2k токенов = ~200k/день.
LLM_PROVIDER=gemini

# [REQUIRED] API-ключ выбранного провайдера. Для ollama не нужен.
LLM_API_KEY=

# Модель провайдера. Дефолты:
#   gemini    → gemini-2.5-flash
#   openai    → gpt-4o-mini
#   anthropic → claude-haiku-4-5-20251001
#   ollama    → gemma3:12b
LLM_MODEL=

# Только для ollama: URL до сервера (по умолчанию http://localhost:11434)
# OLLAMA_BASE_URL=http://ollama:11434

# Жёсткий лимит LLM-вызовов на юзера в час (защита от ddos и от
# выжигания твоей квоты). 5 — нормально для домашней няньки.
LLM_RATE_PER_USER_HOURLY=5

# ─── Безопасность ────────────────────────────────────────────
# [REQUIRED] Случайная строка ≥32 символа для подписи веб-сессий и
# CSRF-токенов. Сгенерируй: openssl rand -hex 32
SECRET_KEY=

# [REQUIRED] Ключ для шифрования голосового дневника и расшифровок
# at-rest. Сгенерируй: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВАЖНО: при смене ключа все старые записи дневника станут нечитаемыми!
DIARY_ENCRYPTION_KEY=

# ─── База данных ─────────────────────────────────────────────
# Через docker-compose Postgres уже включён, эти значения работают
# из коробки. Если хочешь external Postgres — замени.
DB_DSN=postgresql+asyncpg://callendulla:change_me@postgres:5432/callendulla
DB_DSN_SYNC=postgresql+psycopg2://callendulla:change_me@postgres:5432/callendulla

# Только для docker-compose — пароль для postgres-контейнера.
# Должен совпадать с паролем в DB_DSN выше.
POSTGRES_PASSWORD=change_me

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Веб-консоль ─────────────────────────────────────────────
# Внешний URL для веб-консоли. Используется в TG-кнопках "открыть
# календарь". Если веб-консоль не нужна — оставь пустым, кнопки исчезнут.
WEB_BASE_URL=

# Длительность веб-сессии в днях
WEB_SESSION_DAYS=7

# ─── HTTP middleware: защита от Host header injection и CORS ─
# Список разрешённых Host header'ов через запятую. Для прод — твой домен
# (или несколько). Дефолт "*" принимает любой → уязвимо к Host injection
# (атакующий шлёт fake Host → твои абс. URL генерятся на его домен).
# Пример: ALLOWED_HOSTS=callendulla.example.com,api.callendulla.example.com
ALLOWED_HOSTS=*

# CORS origins для веб-консоли на другом домене. Пусто = блокирует все
# cross-origin браузерные запросы (правильный дефолт). "*" — только dev.
# Пример: CORS_ORIGINS=https://app.callendulla.example.com
CORS_ORIGINS=

# ─── AGPL §13 source disclosure ──────────────────────────────
# AGPL обязывает любого, кто хостит модифицированную версию как
# network-сервис, давать пользователям доступ к source code. Сервер
# шлёт URL источника в header X-Source-URL в каждом HTTP-ответе,
# плюс есть endpoint GET /source.
#
# Если форкнул и подменил код — ОБЯЗАН поставить URL твоего fork'а,
# иначе нарушаешь §13. Подробности — docs/agpl-compliance.md.
AGPL_SOURCE_URL=https://github.com/jetmil/callendulla

# ─── TTS (голос) ─────────────────────────────────────────────
# Движок: piper (полностью локально, нужны voice-файлы), edge (cloud,
# бесплатный, без ключа, но иногда падает), cosyvoice (премиум,
# нужен отдельный server)
TTS_ENGINE=edge

# Только для cosyvoice:
# COSYVOICE_BASE_URL=http://cosyvoice:5000

# Pre-rendered банки голосовых токенов. Если pull voice-bank релиз
# — путь к разархивированной папке. Если хочешь генерить на лету —
# оставь пустым.
VOICE_BANK_PATH=

# ─── Часовой пояс по умолчанию ───────────────────────────────
# Используется, если юзер не задал свой в настройках. Любая зона
# из IANA database. Примеры: Europe/Moscow, Asia/Yekaterinburg,
# Europe/Berlin, America/New_York.
DEFAULT_TIMEZONE=Europe/Moscow

# ─── Quiet hours по умолчанию ────────────────────────────────
# Локальное время юзера, в которое триггеры не палят.
# Используются как дефолт для новых юзеров; каждый может переопределить.
QUIET_FROM_HOUR=22
QUIET_TO_HOUR=9

# ─── Логи ────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Опционально: Sentry для отслеживания ошибок
# SENTRY_DSN=

# ─── Регистрация ─────────────────────────────────────────────
# Кто может регистрироваться в боте:
#   open      — любой, кто написал /start
#   whitelist — только TG-юзернеймы из WHITELIST_TG_USERNAMES
#   invite    — только по приглашению существующего owner/member
REGISTRATION_MODE=invite

# Только при whitelist: список через запятую, без @
# WHITELIST_TG_USERNAMES=alice,bob_smith

# Лимит на количество событий на одного юзера (защита от DoS)
MAX_EVENTS_PER_USER=500

# Лимит регистраций в час с одного IP (если webhook за nginx)
REGISTRATION_RATE_PER_IP_HOURLY=10
