/.gitleaks.toml         @jetmil
/.github/workflows/     @jetmil
/.pre-commit-config.yaml @jetmil
/Dockerfile             @jetmil
/docker-compose.yml     @jetmil
/deploy/                @jetmil
/docs/agpl-compliance.md @jetmil
